}

/* Product Buttons */
.product-btn-group {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.btn-cart-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ffcccc;
    /* Light red border */
    color: var(--jk-accent);
    background: #fff0f0;
    /* Very light red bg */
    border-radius: 4px;
    transition: all 0.2s;
}

.btn-cart-icon:hover {
    background: var(--jk-accent);
    color: white;
}

.btn-buy-now {
    flex: 1;
