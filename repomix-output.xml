    font-weight: 600;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    text-decoration: none;
}

.btn-buy-now:hover {
    background: #000;
    color: white;
}

/* --- BUTTONS --- */
.btn {
    border-radius: 4px;
    /* Minimal rounding */
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.8rem;
    padding: 10px 20px;
    border: none;
}

.btn-primary,
.btn-danger {
    background-color: var(--jk-accent);
}

.btn-dark {
    background-color: #000;
}

/* --- FOOTER --- */
footer {
    background-color: #fff;
    border-top: 1px solid var(--jk-border);
    padding: 80px 0;
    margin-top: 100px;
}

/* Floating Social Icons */
.floating-social {
