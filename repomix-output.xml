<file path="src/main/resources/static/css/style.css">
/* CSS Variables - Swiss Style Palette */
:root {
    --jk-bg: #FAFAFA;
    /* Off-white background */
    --jk-white: #FFFFFF;
    /* Pure white for cards */
    --jk-text: #212529;
    /* Dark Grey for text */
    --jk-accent: #D32F2F;
    /* Deep Red Accent */
    --jk-border: #EEEEEE;
    /* Very subtle border */
    --header-height: 100px;
}

body {
    font-family: 'Helvetica Neue', 'Roboto', sans-serif;
    background-color: var(--jk-bg);
    color: var(--jk-text);
    padding-top: var(--header-height);
    line-height: 1.6;
}

h1,
h2,
h3,
h4,
h5,
h6 {
    font-weight: 700;
    letter-spacing: -0.5px;
    /* Tighter letter spacing for headings */
    color: #000;
}

/* --- NAVBAR STYLES (Minimalist) --- */
.navbar-jenka {
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: none;
    /* Remove shadow for cleaner look */
    border-bottom: 1px solid var(--jk-border);
    padding: 0;
    height: var(--header-height);
}

.nav-link {
    font-weight: 700;
    color: #000 !important;
    text-transform: uppercase;
    font-size: 0.75rem;
    padding: 0 12px !important;
    letter-spacing: 0.5px;
    transition: color 0.2s;
}

.nav-link:hover,
.nav-link.active {
    color: var(--jk-accent) !important;
}

.cart-icon-wrap {
    color: #000;
}

.cart-badge {
    background-color: var(--jk-accent);
    font-size: 0.6rem;
}

/* --- DROPDOWN MENU STYLES --- */
.dropdown-menu {
    border: none;
    border-radius: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    margin-top: 0;
    padding: 0;
}

.dropdown-item {
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 12px 20px;
    color: #212529;
    background-color: transparent;
    transition: all 0.2s;
    border-bottom: 1px solid #f8f9fa;
}

.dropdown-item:last-child {
    border-bottom: none;
}

.dropdown-item:hover,
.dropdown-item:focus {
    background-color: #fafafa;
    color: var(--jk-accent);
}


/* --- HERO SECTION --- */
/* Ensure layout is clean */
.hero-img {
    height: 80vh;
    /* Controlled height - Increased to 80vh */
    object-fit: cover;
}

/* --- UTILITIES & OVERRIDES --- */
.text-danger {
    color: var(--jk-accent) !important;
}

.bg-danger {
    background-color: var(--jk-accent) !important;
}

.text-warning {
    color: #FBC02D !important;
    /* Muted gold instead of bright yellow */
}

.hover-shadow,
.product-card {
    background: var(--jk-white);
    border: none !important;
    /* No borders */
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* --- CATEGORY MENU --- */
.category-menu-wrapper {
    margin-top: 3rem;
    margin-bottom: 3rem;
}

.category-item-container {
    text-align: center;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.category-item-container:hover {
    transform: translateY(-5px);
}

.category-image-box {
    border: none;
    border-radius: 8px;
    padding: 10px;
    background-color: #fff;
    margin-bottom: 12px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: box-shadow 0.3s ease;
}

.category-item-container:hover .category-image-box {
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
}

.category-image-box img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border: none !important;
    /* Ensure no image border */
    outline: none !important;
}

.category-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #212529;
    line-height: 1.3;
}

/* --- PRODUCT CARDS (Swiss Grid) --- */
/* --- PRODUCT CARDS (Swiss Grid) --- */
.product-card {
    border-radius: 0;
    /* Square edges */
    padding: 15px;
    text-align: left;
    /* Left align as per reference */
    border: 1px solid transparent;
    /* Placeholder for hover border */
    transition: all 0.3s ease;
}

.product-card .card-img-top {
    height: 200px;
    /* Fixed height for uniformity */
    width: 100%;
    object-fit: contain;
    /* Prevent distortion, show full image */
    padding: 10px;
    /* Internal spacing */
    background-color: #fff;
