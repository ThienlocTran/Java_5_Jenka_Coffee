    transition: all 0.2s ease;
}

.otp-input-field:focus {
    outline: none;
    border-color: #212529;
    background: #FFFFFF;
}

.otp-input-field:disabled {
    background: #F5F5F5;
    opacity: 0.6;
    cursor: not-allowed;
}

/* Buttons */
.otp-btn-primary {
    width: 100%;
    padding: 14px;
    font-size: 14px;
    font-weight: 500;
    background: #212529;
    color: #FAFAFA;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
}

.otp-btn-primary:hover:not(:disabled) {
    background: #000000;
}

.otp-btn-primary:active:not(:disabled) {
    transform: translateY(1px);
}

.otp-btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.otp-btn-link {
    background: none;
    border: none;
    color: #212529;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.2s ease;
}

.otp-btn-link:hover:not(:disabled) {
    color: #D32F2F;
}

.otp-btn-link:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Resend Section */
.otp-resend-section {
    text-align: center;
    margin-top: 16px;
}

.otp-resend-text {
    color: #6c757d;
    font-size: 13px;
    margin-bottom: 8px;
}

.otp-resend-timer {
    font-weight: 600;
    color: #D32F2F;
}

/* Footer */
.otp-card-footer {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #E0E0E0;
    text-align: center;
}

.otp-card-footer a {
    color: #212529;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s ease;
}

.otp-card-footer a:hover {
    color: #D32F2F;
}

/* Alerts */
.otp-alert {
    padding: 12px 16px;
    margin-bottom: 24px;
    font-size: 13px;
    border-left: 3px solid;
    display: flex;
    align-items: center;
    gap: 8px;
}

.otp-alert-success {
    background: #F0FDF4;
    border-left-color: #16A34A;
    color: #16A34A;
}

.otp-alert-danger {
    background: #FEF2F2;
    border-left-color: #D32F2F;
    color: #D32F2F;
}

.otp-alert-close {
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    opacity: 0.7;
    padding: 0;
    font-size: 16px;
}

.otp-alert-close:hover {
    opacity: 1;
}
</file>

