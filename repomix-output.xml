    Title NVARCHAR(255) NOT NULL,
    Content NVARCHAR(MAX) NULL,
    Image NVARCHAR(500) NULL,
    CreateDate DATETIME DEFAULT GETDATE(),
    Available BIT DEFAULT 1,
    PRIMARY KEY (Id)
);
