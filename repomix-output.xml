}

.news-title {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 10px;
    color: #000;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    /* Fix lint: standard property */
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
}

.news-summary {
    font-size: 0.85rem;
    color: #666;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
