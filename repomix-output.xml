}

.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
    border-color: var(--jk-border);
}

.card-title {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
